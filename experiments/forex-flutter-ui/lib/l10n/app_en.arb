  "helpTitle": "NeoEthos · Help",
  "helpWelcomeTitle": "Welcome",
  "helpWelcomeOverviewHeading": "NeoEthos — Quick overview",
  "helpWelcomeOverviewP1": "NeoEthos is a ",
  "helpWelcomeOverviewP2": " with built-in AI. It connects to a broker (cTrader; DXtrade soon), supports manual trading with indicators and drawing tools, and has two AI engines: ",
  "helpWelcomeOverviewP3": " (genetic strategy search) and ",
  "helpWelcomeOverviewP4": " (ensemble ML training). Every value comes from the broker — nothing is hardcoded.",
  "helpWelcomeFlowHeading": "Recommended flow for new users",
  "helpWelcomeStep1Label": "Open a Demo account",
  "helpWelcomeStep1Body": " at a cTrader broker (Pepperstone, IC Markets, FxPro, Vantage, Axi)",
  "helpWelcomeStep2Label": "Connect the broker",
  "helpWelcomeStep3Label": "Pick pairs",
  "helpWelcomeStep3Body": " in Market Watch — start with EUR/USD or GBP/USD",
  "helpWelcomeStep4Label": "Place a small manual trade",
  "helpWelcomeStep4Body": " (0.01 lots) to confirm everything works",
  "helpWelcomeStep5Body": " to find strategies (10-30 minutes)",
  "helpWelcomeStep6Label": "Run Training",
  "helpWelcomeStep6Body": " on those strategies",
  "helpWelcomeStep7Label": "Validate for 2 weeks",
  "helpWelcomeStep7Body": " on demo before considering live",
  "helpWelcomeTip": "Reminder: 75-90% of retail FX traders lose money. Always validate on demo for weeks before increasing risk.",
  "helpTradingManualHeading": "Manual trading",
  "helpTradingManualP1": "The ",
  "helpTradingManualP2": " shows BUY (green) and SELL (red) buttons with the current bid/ask. Before submitting:",
  "helpTradingOrderType": "Market (immediate), Limit (wait for better entry), Stop (wait for breakout)",
  "helpTradingLots": "position size. 0.01 lot = 1,000 units (micro lot). For EUR/USD a pip ≈ $0.10 per 0.01 lot",
  "helpTradingAutoLot": "automatic lot sizing from your risk %",
  "helpTradingSlTp": "Stop Loss & Take Profit based on volatility",
  "helpTradingRr": "Risk/Reward ratio — 1:2 means for every $1 risk you target $2 profit",
  "helpChartLiveHeading": "Live data — not stored",
  "helpChartLiveP1": "The chart shows ",
  "helpChartLiveP1Bold": "live candles straight from the broker",
  "helpChartLiveP2": " (cTrader trendbars), not a stale snapshot off disk. The last candle moves in real time from the spot stream.",
  "helpChartScrollbackHeading": "Scroll-back — pan years into the past (TradingView model)",
  "helpChartScrollbackP1": "Drag the chart ",
  "helpChartScrollbackLeft": "left",
  "helpChartScrollbackP2": " past the oldest loaded candle and NeoEthos auto-loads the next page of older bars live from the broker. ",
  "helpChartScrollbackP3Bold": "They stay in memory only — they never touch the disk.",
  "helpChartScrollbackP4": " Pan two years back at zero disk cost.",
  "helpChartTip": "For very deep scroll-back on M1 (millions of candles), switch to a higher timeframe (H1/H4/D1) — same as any professional terminal.",
  "helpChartControlsHeading": "Controls",
  "helpChartZoomLabel": "Zoom: ",
  "helpChartZoomBody": "scroll / pinch on the chart",
  "helpChartCrosshairLabel": "OHLC crosshair: ",
  "helpChartCrosshairBody": "long-press to read open/high/low/close on any candle",
  "helpChartOverlaysLabel": "Overlays / sub-panels: ",
  "helpChartOverlaysBody": "MA · BOLL (top) and MACD · KDJ · RSI · WR (bottom) — computed live on broker data",
  "helpChartAccountSwitcherLabel": "Account switcher: ",
  "helpChartAccountSwitcherBody": "change account (DEMO/LIVE) from the top-bar dropdown",
  "helpAiTitle": "AI Engine",
  "helpAiPipelineHeading": "Strategy Lab — How the pipeline works",
  "helpAiPipelineP1": "One unified 5-stage flow: Data Ready → Discovery → Training → Validation → Promotion Gate. Each stage has its own params and the next consumes the previous automatically.",
  "helpAiDiscoveryHeading": "Discovery — Genetic strategy search",
  "helpAiDiscoveryP1": "Creates random strategies from indicator combinations, evaluates them on history, keeps the best and crosses them over generations.",
  "helpAiTrainingHeading": "Training — Multi-model ensemble",
  "helpAiTrainingP1": "Features (indicators, OHLCV, volatility, session, news) feed 30 models in parallel — Tree (LightGBM, XGBoost, CatBoost), Deep (MLP, KAN, TabNet), Time-series (NBeats, TiDE, PatchTST, TimesNet, Transformer), Meta (logistic, calibration, stacker, HMM regime), RL+Exit (DQN, ExitAgent). ",
  "helpAiTrainingP1Bold": "Genetic/NeuroEvo/NEAT are Discovery-only — not ensemble voters.",
  "helpAiValidationHeading": "Validation + Promotion Gate",
  "helpAiValidationP1": "Before a trained ensemble reaches live, it passes Walk-Forward Analysis, Monte Carlo sensitivity sweeps, and a Promotion Gate that checks Sharpe, Calmar, win rate and drawdown.",
  "helpRiskTitle": "Risk",
  "helpRiskHeading": "Risk management — 3 modes",
  "helpRiskStandardLabel": "🏦 Standard account: ",
  "helpRiskStandardBody": "regular retail. Risk 0.5-2% per trade, daily DD ≤ 5%.",
  "helpRiskPropFirmLabel": "🏆 Prop firm challenge: ",
  "helpRiskPropFirmBody": "hard daily/total drawdown limits (FTMO, FundedNext etc.).",
  "helpRiskRiskyLabel": "⚡ Risky Mode (account multiplication): ",
  "helpRiskRiskyBody": "aggressive compounding from a small balance ($20 → $50K). Includes time-to-target percentiles (p10/p50/p90) and probability-of-ruin via Brownian Barrier.",
  "helpRiskRiskyHeading": "How Risky Mode works",
  "helpRiskRiskyP1": "Risky Mode is ",
  "helpRiskRiskyP2": " a hardcoded \"20 pip challenge\". It is Kelly-aligned compounding with 11 logarithmic stages from $20 → $50K. Time-to-target ETA via Brownian inversion + Beasley-Springer-Moro inverse-normal-CDF (~1e-5 accuracy). Goal: grow the account as fast as safely possible.",
  "helpRiskTip": "⚠ 75-90% of retail FX traders lose money. Risky Mode = aggressive ≠ safe. Always validate on demo for weeks first.",
  "helpDataTitle": "Data & Disk",
  "helpDataSourceHeading": "Where data comes from",
  "helpDataSourceP1": "There are ",
  "helpDataSourceP1Bold": "two separate sources",
  "helpDataSourceP2": " — the difference matters:",
  "helpDataLiveLabel": "Live (broker): ",
  "helpDataLiveBody": "Chart, Market Watch, indicators, scroll-back. Straight from the broker and ",
  "helpDataLiveBodyBold": "NOT written to disk.",
  "helpDataCacheLabel": "Local Vortex cache: ",
  "helpDataCacheBody": "only Discovery and Training need stored history for backtest/training — ",
  "helpDataCacheBodyBold": "that",
  "helpDataCacheBody2": " is written to disk.",
  "helpDataWritesHeading": "What writes to disk",
  "helpDataBootstrapBody": " (Settings → Data): explicit download of a history window for a symbol/timeframe.",
  "helpDataAutofetchBody": "if there isn't enough history when you run discovery, it downloads it automatically (~N years, controlled by NEOETHOS_BOT_MIN_HISTORY_YEARS) and stores it.",
  "helpDataDirBody": "the storage folder — set in Settings → Data.",
  "helpDataTip": "Viewing a chart — even panning years back — does NOT fill the disk. Only Data Bootstrap and Discovery persist history, because backtest/training needs it.",
  "helpDataSymbolsHeading": "Supported symbols",
  "helpDataSymbolsP1": "The symbol list comes from the broker but is restricted to ",
  "helpDataSymbolsP1Bold": "forex, metals, indices and commodities",
  "helpDataSymbolsP2": " — the broker's stocks and ETFs are excluded automatically (the engine never trades them).",
