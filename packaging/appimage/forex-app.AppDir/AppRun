#!/usr/bin/env bash
# AppRun — AppImage entry point for forex-app.
#
# Spec: https://docs.appimage.org/packaging-guide/manual.html
#       https://github.com/AppImage/AppImageKit/blob/master/README.md
#
# AppImage runtime mounts the .AppDir at $APPDIR and executes this script.
# We forward to the bundled forex-app binary under usr/bin/.
#
# Strategy ref: installer_no_paid_certs_strategy.md §3 (Linux AppImage path,
# $0/yr, GPG-signed via `appimagetool -s --sign-key`).

set -euo pipefail

# $APPDIR is set by the AppImage runtime to the FUSE mount point of the .AppDir.
# Fall back to the directory of this script if invoked directly (e.g. unpacked).
APPDIR="${APPDIR:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)}"

# Ensure bundled libraries (if any are added later, e.g. libtorch under
# usr/lib/) are picked up by the dynamic linker without requiring system
# installs. AppImage spec §5 (Library path discovery).
export LD_LIBRARY_PATH="${APPDIR}/usr/lib:${LD_LIBRARY_PATH:-}"

# Point the binary at the canonical XDG data dir for our shipped defaults.
# The wizard reads from $XDG_DATA_HOME/forex-ai/... at runtime; the bundled
# defaults are copied there on first launch by the in-app initialiser.
export FOREX_AI_BUNDLED_DATA="${APPDIR}/usr/share/forex-ai"

exec "${APPDIR}/usr/bin/forex-app" "$@"
