[Desktop Entry]
# XDG Desktop Entry — https://specifications.freedesktop.org/desktop-entry-spec/
# Required by AppImage spec; appimagetool reads this to populate the
# launcher's icon, name, and MIME associations.
Type=Application
Version=1.5
Name=forex-ai
GenericName=Quantitative Trading Workspace
Comment=Quantitative trading workspace for the cTrader Open API
Exec=forex-app %U
# Icon name (without extension) — must match a file under
# usr/share/icons/hicolor/<size>/apps/<Icon>.png OR a top-level
# .AppDir/<Icon>.png per AppImage convention.
Icon=forex-app
Terminal=false
Categories=Finance;Office;
Keywords=forex;trading;quant;ctrader;
StartupNotify=true
StartupWMClass=forex-app
