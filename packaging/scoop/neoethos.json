{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "0.4.20",
    "description": "Quantitative trading workspace for the cTrader Open API.",
    "homepage": "https://github.com/kosred/neoethos",
    "license": "LicenseRef-Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://github.com/kosred/neoethos/releases/download/v0.4.20/neoethos_0.4.20_x64-setup.exe",
            "hash": ""
        }
    },
    "installer": {
        "script": [
            "$installer_path = \"$dir\\$fname\"",
            "Start-Process -FilePath $installer_path -ArgumentList '/S',\"/D=$dir\" -Wait",
            "Remove-Item -Path $installer_path -Force"
        ]
    },
    "uninstaller": {
        "script": [
            "Start-Process -FilePath \"$dir\\uninstall.exe\" -ArgumentList '/S' -Wait"
        ]
    },
    "bin": [
        "neoethos.exe"
    ],
    "shortcuts": [
        [
            "neoethos.exe",
            "neoethos"
        ]
    ],
    "persist": [
        "config",
        "data",
        "logs"
    ],
    "checkver": {
        "github": "https://github.com/kosred/neoethos"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/kosred/neoethos/releases/download/v$version/neoethos_$version_x64-setup.exe"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
